@@ -29,7 +30,7 @@ function (ResponseInterface $response): ResponseInterface {
                         new OpenAiHeaderBag(
                             requestId: $response->getHeaderLine('x-request-id') ?: null,
                             rateLimitTokensRemaining: $remaining !== '' ? (int) $remaining : null,
-                            rateLimitTokensReset: $reset ?: null,
